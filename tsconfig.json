{
    "compilerOptions": {
        "target": "ESNext",
        "module": "node16",
        "moduleResolution": "node16",
        "rootDir": "./src",
        "outDir": "./dist",
        "lib": [
            "ESNext",
            "DOM"
        ],
        "strict": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
    },
    "include": [
        "src/**/*"
    ]
}